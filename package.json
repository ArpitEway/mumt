{
  "name": "mumt-fullstack",
  "private": true,
  "version": "1.0.0",
  "description": "React frontend and Node backend for the mumt/MySQL project.",
  "workspaces": [
    "backend",
    "frontend",
    "shared"
  ],
  "scripts": {
    "start": "node app.js",
    "dev": "concurrently \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:push": "turbo run db:push",
    "db:migrate": "turbo run db:migrate"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "turbo": "^1.10.5"
  }
}
